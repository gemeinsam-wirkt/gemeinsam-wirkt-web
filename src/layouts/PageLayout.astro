---
/*
  Standard-Layout für Inhaltsseiten: Seitenkopf (Titel + optionaler Lead)
  und ein zentrierter Inhaltsbereich. Baut auf BaseLayout auf.
*/
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  /** Einleitender Satz unter der Überschrift. */
  lead?: string;
  /** Begrenzt die Inhaltsbreite auf Lesebreite (für Fließtext). */
  narrow?: boolean;
}
const { title, description, lead, narrow = false } = Astro.props;
---

<BaseLayout title={title} description={description ?? lead}>
  <header class="page-head">
    <div class="container">
      <p class="page-head__eyebrow">
        <a href="/">Start</a>
      </p>
      <h1>{title}</h1>
      {lead && <p class="page-head__lead">{lead}</p>}
    </div>
  </header>

  <div class:list={['container', 'page-body', { 'page-body--narrow': narrow }]}>
    <slot />
  </div>
</BaseLayout>

<style>
  .page-head {
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
    padding-block: var(--space-12);
  }
  .page-head__eyebrow {
    font-family: var(--font-display);
    font-size: var(--fs-300);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .page-head__eyebrow a {
    color: var(--c-muted);
    text-decoration: none;
  }
  .page-head__eyebrow a:hover {
    color: var(--c-blue-900);
  }
  .page-head__lead {
    margin-top: var(--space-4);
    font-size: var(--fs-500);
    color: var(--c-muted);
    max-width: var(--measure);
  }

  .page-body {
    padding-block: var(--space-16);
  }
  .page-body--narrow :global(.prose),
  .page-body.page-body--narrow {
    max-width: var(--measure);
  }
</style>
