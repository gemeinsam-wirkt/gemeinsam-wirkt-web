---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Card from '../../../components/Card.astro';
import { ui } from '../../../i18n/ui';
import { formatDate } from '../../../i18n/utils';

const t = ui.de;
const base = '/projekte-und-veranstaltungen/podcasts';

const folgen = (await getCollection('podcast', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.episodennummer - a.data.episodennummer,
);
---

<PageLayout
  title="Podcasts"
  lead="Wir machen hörbar, was wir lernen: Gespräche über Zusammenarbeit, geschützte Räume und das, was Kooperation gelingen lässt."
>
  {
    folgen.length === 0 ? (
      <p class="empty">{t['list.empty']}</p>
    ) : (
      <div class="cards">
        {folgen.map((entry) => (
          <Card
            title={entry.data.titel}
            href={`${base}/${entry.id}`}
            badge={`${t['podcast.episode']} ${entry.data.episodennummer}`}
            meta={formatDate(entry.data.datum)}
          >
            {entry.data.beschreibung}
          </Card>
        ))}
      </div>
    )
  }
</PageLayout>

<style>
  .cards {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
  }
  .empty {
    color: var(--c-muted);
  }
</style>
