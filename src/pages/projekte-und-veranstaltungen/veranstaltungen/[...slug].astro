---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { ui } from '../../../i18n/ui';
import { formatDateTime } from '../../../i18n/utils';

export async function getStaticPaths() {
  const events = await getCollection('veranstaltungen', ({ data }) => !data.draft);
  return events.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const t = ui.de;
const d = entry.data;
---

<BaseLayout title={d.titel} description={d.kurzbeschreibung}>
  <article class="container article">
    <p class="article__back">
      <a href="/projekte-und-veranstaltungen/veranstaltungen">← {t['back']}</a>
    </p>
    <h1>{d.titel}</h1>

    <dl class="facts">
      <div>
        <dt>{t['event.when']}</dt>
        <dd>
          <time datetime={d.start.toISOString()}>{formatDateTime(d.start)}</time>
          {d.ende && <> – <time datetime={d.ende.toISOString()}>{formatDateTime(d.ende)}</time></>}
        </dd>
      </div>
      <div>
        <dt>{t['event.where']}</dt>
        <dd>{d.ort}</dd>
      </div>
    </dl>

    <p class="article__teaser">{d.kurzbeschreibung}</p>
    <div class="prose flow">
      <Content />
    </div>

    {
      d.anmeldungUrl && (
        <p class="cta">
          <a class="btn btn--primary" href={d.anmeldungUrl} rel="noopener">
            {t['event.register']}
          </a>
        </p>
      )
    }
  </article>
</BaseLayout>

<style>
  .article {
    padding-block: var(--space-16);
    max-width: var(--measure);
  }
  .article__back {
    margin-bottom: var(--space-6);
  }
  .article__back a {
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .facts {
    display: grid;
    gap: var(--space-4);
    margin-block: var(--space-6);
    padding: var(--space-4) var(--space-6);
    background: var(--c-surface);
    border-radius: var(--radius);
  }
  @media (min-width: 30rem) {
    .facts {
      grid-template-columns: 1fr 1fr;
    }
  }
  .facts dt {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-300);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-muted);
  }
  .facts dd {
    margin: 0;
  }
  .article__teaser {
    font-size: var(--fs-500);
    color: var(--c-muted);
    margin-bottom: var(--space-8);
  }
  .cta {
    margin-top: var(--space-8);
  }
</style>
