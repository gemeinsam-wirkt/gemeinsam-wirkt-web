---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { ui } from '../i18n/ui';

const sponsoren = (await getCollection('partner')).filter(
  (p) => p.data.typ === 'sponsor',
);
const t = ui.de;
---

<PageLayout
  title="Sponsoren"
  lead="Diese Förderer machen unsere Kooperationsräume möglich. Danke, dass ihr an die Idee glaubt und sie tragt."
>
  {
    sponsoren.length === 0 ? (
      <p class="empty">{t['list.empty']}</p>
    ) : (
      <ul class="partner-grid">
        {sponsoren.map(({ data }) => (
          <li class="partner">
            {data.logo && <img src={data.logo} alt="" width="120" height="60" />}
            <span class="partner__name">{data.name}</span>
            {data.url && (
              <a href={data.url} rel="noopener">
                Zur Website →
              </a>
            )}
          </li>
        ))}
      </ul>
    )
  }

  <div class="prose flow cta-block">
    <h2>Du möchtest uns fördern?</h2>
    <p>
      Wenn du unsere Arbeit unterstützen willst, lass uns sprechen. Wir zeigen dir
      gern, was deine Förderung konkret bewirkt.
    </p>
    <a class="btn btn--secondary" href="/kontakt">Kontakt aufnehmen</a>
  </div>

  <p class="note">Logos und Sponsoren sind Platzhalter und werden vor dem Livegang ersetzt.</p>
</PageLayout>

<style>
  .partner-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 14rem), 1fr));
  }
  .partner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    text-align: center;
    align-items: center;
  }
  .partner img {
    object-fit: contain;
    opacity: 0.9;
  }
  .partner__name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--c-blue-900);
  }
  .partner a {
    font-size: var(--fs-300);
    text-decoration: none;
  }
  .empty {
    color: var(--c-muted);
  }
  .cta-block {
    margin-top: var(--space-16);
  }
</style>
