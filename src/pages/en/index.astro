---
/*
  EN ist strukturell vorbereitet, aber in dieser Phase NICHT inhaltlich befüllt
  (CLAUDE.md, Abschnitt 7). Diese Stub-Seite verhindert, dass der
  Sprachumschalter ins Leere läuft. Weitere /en-Seiten folgen später.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="English" description="The English version of this site is in preparation.">
  <section class="container coming-soon">
    <h1>English version coming soon</h1>
    <p>
      We are still building the English pages. In the meantime, you are welcome to
      explore the German version of our site.
    </p>
    <p><a class="btn btn--secondary" href="/">Zur deutschen Startseite</a></p>
  </section>
</BaseLayout>

<style>
  .coming-soon {
    padding-block: var(--space-24);
    max-width: var(--measure);
  }
  .coming-soon p {
    margin-top: var(--space-4);
  }
</style>
