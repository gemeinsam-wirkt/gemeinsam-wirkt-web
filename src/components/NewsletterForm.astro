---
/*
  Newsletter-Anmeldung (Platzhalter, CLAUDE.md Abschnitt 5).
  Der Versand läuft später vollständig über einen EU-ESP (rapidmail/CleverReach/
  Brevo – Wahl offen). Hier steht nur das Anmeldeformular mit Double-Opt-In-Hinweis.
  Das <form> ist bewusst ohne echtes `action` – beim Anbinden des ESP ersetzen.
*/
import { ui } from '../i18n/ui';
const t = ui.de;
---

<section class="newsletter" aria-labelledby="newsletter-title">
  <div class="newsletter__text">
    <h2 id="newsletter-title">{t['newsletter.title']}</h2>
    <p>{t['newsletter.text']}</p>
  </div>

  <form class="newsletter__form" method="post" action="#" aria-describedby="newsletter-note">
    <div class="field">
      <label for="newsletter-email">{t['newsletter.email']}</label>
      <input
        type="email"
        id="newsletter-email"
        name="email"
        autocomplete="email"
        required
        placeholder={t['newsletter.email.placeholder']}
      />
    </div>
    <button type="submit" class="btn btn--primary">{t['newsletter.submit']}</button>
    <p id="newsletter-note" class="newsletter__note">{t['newsletter.note']}</p>
    <p class="newsletter__dev">{t['newsletter.placeholder']}</p>
  </form>
</section>

<style>
  .newsletter {
    display: grid;
    gap: var(--space-8);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: var(--space-8);
  }
  @media (min-width: 48rem) {
    .newsletter {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: var(--space-12);
    }
  }

  .newsletter h2 {
    margin-bottom: var(--space-3);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .field label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-300);
  }
  .field input {
    padding: var(--space-3);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    background: var(--c-white);
  }
  .field input:focus-visible {
    outline: 2px solid var(--c-blue-600);
    outline-offset: 1px;
  }

  .newsletter__note {
    margin-top: var(--space-3);
    font-size: var(--fs-300);
    color: var(--c-muted);
    max-width: 50ch;
  }
  .newsletter__dev {
    margin-top: var(--space-3);
    font-size: var(--fs-300);
    color: var(--c-accent-ink);
    background: #fdf1e7;
    border: 1px dashed var(--c-accent);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    max-width: 50ch;
  }
</style>
