---
/*
  Karte für eine Veranstaltung: Datum, Ort, Kurzbeschreibung, optionaler
  externer Anmeldelink (anmeldungUrl). Datum lokalisiert formatiert.
*/
import { formatDateTime } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  titel: string;
  href: string;
  start: Date;
  ort: string;
  kurzbeschreibung: string;
  anmeldungUrl?: string;
}
const { titel, href, start, ort, kurzbeschreibung, anmeldungUrl } = Astro.props;
const t = ui.de;
---

<article class="event">
  <div class="event__body">
    <p class="event__meta">
      <time datetime={start.toISOString()}>{formatDateTime(start)}</time>
      <span aria-hidden="true">·</span>
      <span>{ort}</span>
    </p>
    <h3 class="event__title"><a href={href}>{titel}</a></h3>
    <p>{kurzbeschreibung}</p>
  </div>
  {anmeldungUrl && (
    <a class="btn btn--primary event__cta" href={anmeldungUrl} rel="noopener">
      {t['event.register']}
    </a>
  )}
</article>

<style>
  .event {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-left: 4px solid var(--c-green-500);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .event__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--fs-300);
    color: var(--c-muted);
    font-family: var(--font-display);
    font-weight: 600;
  }
  .event__title {
    font-size: var(--fs-500);
  }
  .event__title a {
    text-decoration: none;
    color: var(--c-blue-900);
  }
  .event__title a:hover {
    text-decoration: underline;
  }
  .event__cta {
    align-self: flex-start;
  }
</style>
